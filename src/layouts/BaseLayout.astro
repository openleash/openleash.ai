---
import JsonLd from '../components/JsonLd.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description = 'Open-source authorization framework for AI agents. Define YAML policies, issue PASETO proof tokens, and add human-in-the-loop approvals.',
  ogImage = '/og.png',
  canonicalPath,
  jsonLd = [],
} = Astro.props;

const site = Astro.site?.origin ?? 'https://openleash.ai';
const canonical = canonicalPath ? `${site}${canonicalPath}` : Astro.url.href;

const globalSchemas: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'OpenLeash',
    url: site,
    logo: `${site}/brand/openleash-mark.svg`,
    sameAs: ['https://github.com/openleash/openleash'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'OpenLeash',
    url: site,
  },
  ...jsonLd,
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050a0e" />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg" />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${site}${ogImage}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="OpenLeash" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}${ogImage}`} />

    <!-- AI agent discovery -->
    <link rel="help" href="/llms.txt" type="text/plain" title="LLM agent instructions" />
    <link rel="help" href="/skill.md" type="text/markdown" title="AI agent skill reference" />
    <meta name="robots" content="index, follow" />
    <meta name="ai-agent-start" content="https://github.com/openleash/openleash/blob/main/AGENTS.md" />
    <meta name="ai-purpose" content="Authorization sidecar for AI agents. Call POST /v1/authorize before risky actions." />

    <!-- JSON-LD structured data -->
    <JsonLd schemas={globalSchemas} />
  </head>
  <body>
    <div class="stars"></div>
    <div class="nebula"></div>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
