  }

  .page-desc {
    max-width: 680px;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .page-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .meta-sep {
    color: var(--text-muted);
  }

  .content {
    position: relative;
    z-index: 1;
    margin-bottom: 48px;
  }

  .content-section {
    margin-bottom: 36px;
  }

  .content-section h2 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text-primary);
  }

  .content-section h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin-top: 20px;
    margin-bottom: 8px;
    color: var(--text-primary);
  }

  .content-section p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
    max-width: 680px;
  }

  .content-section ul,
  .content-section ol {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
    max-width: 680px;
    padding-left: 24px;
  }

  .content-section li {
    margin-bottom: 6px;
  }

  .content-section em {
    color: var(--text-primary);
    font-style: italic;
  }

  .content-section a {
    color: var(--green-bright);
    text-decoration: none;
    transition: color 0.2s var(--ease-out);
  }

  .content-section a:hover {
    color: var(--amber-bright);
  }

  .content-section code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--green-bright);
    background: rgba(52, 211, 153, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .content-section strong {
    color: var(--text-primary);
  }

  /* Comparison table */
  .comparison-table {
    max-width: 680px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 16px;
  }

  .comparison-row {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 0;
  }

  .comparison-row > span {
    padding: 10px 14px;
    font-size: 0.85rem;
    border-bottom: 1px solid var(--border-subtle);
    border-right: 1px solid var(--border-subtle);
  }

  .comparison-row > span:last-child {
    border-right: none;
  }

  .comparison-row:last-child > span {
    border-bottom: none;
  }

  .comparison-header > span {
    font-weight: 600;
    color: var(--text-primary);
    background: rgba(0, 0, 0, 0.3);
  }

  .comparison-feature {
    color: var(--text-primary);
    font-weight: 500;
  }

  .comparison-jwt {
    color: var(--text-secondary);
  }

  .comparison-paseto {
    color: var(--green-bright);
  }

  @media (max-width: 640px) {
    .comparison-row {
      grid-template-columns: 1fr;
    }

    .comparison-row > span {
      border-right: none;
    }

    .comparison-header {
      display: none;
    }

    .comparison-feature {
      background: rgba(0, 0, 0, 0.2);
      font-weight: 600;
    }
  }
</style>
