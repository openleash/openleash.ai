  dateModified="2026-04-10"
  jsonLd={[{
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'What is AI Agent Authorization?',
    description: 'AI agent authorization explained: why autonomous agents need policy-based governance, how cryptographic proof tokens work, and how OpenLeash implements human-in-the-loop controls.',
    datePublished: '2026-04-01',
    dateModified: '2026-04-10',
    author: { '@type': 'Organization', name: 'OpenLeash', url: 'https://openleash.ai' },
    publisher: { '@type': 'Organization', name: 'OpenLeash', url: 'https://openleash.ai', logo: { '@type': 'ImageObject', url: 'https://openleash.ai/brand/openleash-mark.svg' } },
