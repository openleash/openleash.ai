<script>
  fetch('https://api.github.com/repos/openleash/openleash/releases/latest')
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(data => {
      const el = document.getElementById('hero-version');
      const tag = document.getElementById('version-tag');
      const link = document.getElementById('version-link');
      if (el && tag && link && data.tag_name) {
        tag.textContent = data.tag_name;
        link.href = data.html_url;
        el.style.display = '';
      }
    })
    .catch(() => {});
</script>
