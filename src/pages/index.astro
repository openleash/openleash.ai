---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FeatureCard from '../components/FeatureCard.astro';
import TransactionFlow from '../components/TransactionFlow.astro';
import CalloutBanner from '../components/CalloutBanner.astro';
import QuickStart from '../components/QuickStart.astro';
---

<BaseLayout
  title="OpenLeash — Open-Source Authorization for AI Agents"
  description="Open-source authorization framework for AI agents. Define YAML policies, issue PASETO proof tokens, and add human-in-the-loop approvals. SDKs for TypeScript, Python, and Go."
  ogImage="/og/index.png"
  canonicalPath="/"
  keywords="AI agent authorization, open source, PASETO proof tokens, YAML policies, human-in-the-loop, TypeScript SDK, Python SDK, Go SDK, agent guardrails, MCP authorization"
  jsonLd={[{
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'OpenLeash',
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Linux, macOS, Windows, Docker',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Open-source authorization framework for AI agents. Define YAML policies, issue PASETO proof tokens, and add human-in-the-loop approvals.',
    license: 'https://www.apache.org/licenses/LICENSE-2.0',
    url: 'https://openleash.ai',
    downloadUrl: 'https://www.npmjs.com/package/@openleash/cli',
    softwareVersion: '0.14.0',
    programmingLanguage: ['TypeScript', 'Python', 'Go'],
  }, {
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: 'OpenLeash Owner Portal Demo',
    description: 'A walkthrough of the OpenLeash owner portal — manage AI agents, authorization policies, approval workflows, and audit logs.',
    thumbnailUrl: 'https://openleash.ai/video/poster.png',
    contentUrl: 'https://openleash.ai/video/pr_video_1.0.mp4',
    uploadDate: '2026-04-06',
    duration: 'PT1M',
  }]}
>
  <Nav />

  <main class="container">
    <!-- Hero -->
    <header class="hero fade-in">
      <div class="hero-icon">
        <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="lobster-svg" aria-label="OpenLeash lobster logo">
          <defs>
            <linearGradient id="hero-lobster-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#34d399"/>
              <stop offset="100%" stop-color="#065f46"/>
            </linearGradient>
          </defs>
          <!-- Body -->
          <path d="M60 10 C32 10 18 30 18 48 C18 66 32 80 46 84 L46 88 L54 88 L54 84 C54 84 60 86 66 84 L66 88 L74 88 L74 84 C88 80 102 66 102 48 C102 30 88 10 60 10Z" fill="url(#hero-lobster-grad)" class="lobster-body"/>
          <!-- Left Claw -->
          <path d="M22 38 C8 34 2 43 6 52 C10 61 20 57 24 48 C27 42 24 38 22 38Z" fill="url(#hero-lobster-grad)" class="lobster-claw-l"/>
          <!-- Right Claw -->
          <path d="M98 38 C112 34 118 43 114 52 C110 61 100 57 96 48 C93 42 96 38 98 38Z" fill="url(#hero-lobster-grad)" class="lobster-claw-r"/>
          <!-- Antennae -->
          <path d="M46 15 Q36 5 31 8" stroke="#34d399" stroke-width="2.5" stroke-linecap="round" class="lobster-antenna"/>
          <path d="M74 15 Q84 5 89 8" stroke="#34d399" stroke-width="2.5" stroke-linecap="round" class="lobster-antenna"/>
          <!-- Eyes -->
          <circle cx="45" cy="30" r="5.5" fill="#050a0e"/>
          <circle cx="75" cy="30" r="5.5" fill="#050a0e"/>
          <circle cx="46" cy="29" r="2" fill="#fbbf24" class="lobster-eye"/>
          <circle cx="76" cy="29" r="2" fill="#fbbf24" class="lobster-eye"/>
          <!-- Collar -->
          <path d="M28 56 C42 64 78 64 92 56" stroke="#fbbf24" stroke-width="4" stroke-linecap="round" fill="none"/>
          <!-- Leash -->
          <path d="M60 62 L60 98 Q58 106 50 108" stroke="#fbbf24" stroke-width="3" stroke-linecap="round" fill="none"/>
          <ellipse cx="45" cy="109" rx="8" ry="4.5" fill="none" stroke="#fbbf24" stroke-width="3"/>
        </svg>
      </div>
      <h1 class="hero-title">
        Open<span class="hero-accent">Leash</span>
      </h1>
      <p class="hero-tagline">Authorization guardrails for AI agents.</p>
      <p class="hero-desc">
        Your agent asks before doing anything risky. You define what's allowed in YAML.
        OpenLeash decides — ALLOW, DENY, or escalate to a human. Every approved action gets
        a cryptographic proof token, verifiable offline by anyone. Local-first, no cloud
        dependency, Apache-2.0.
      </p>
      <div class="hero-version fade-in fade-in-d1" id="hero-version" style="display:none">
        <a id="version-link" href="https://github.com/openleash/openleash/releases/latest" target="_blank" rel="noopener noreferrer" class="version-badge">
          <span id="version-tag"></span>
        </a>
      </div>
      <div class="hero-badges fade-in fade-in-d1">
        <a href="https://github.com/openleash/openleash" target="_blank" rel="noopener noreferrer">
          <img src="https://img.shields.io/github/stars/openleash/openleash?style=flat&logo=github&label=Stars&color=10b981" alt="GitHub Stars" width="auto" height="20" loading="lazy" />
        </a>
        <a href="https://www.npmjs.com/package/@openleash/cli" target="_blank" rel="noopener noreferrer">
          <img src="https://img.shields.io/npm/dm/@openleash/cli?style=flat&logo=npm&label=Downloads&color=10b981" alt="npm Downloads" width="auto" height="20" loading="lazy" />
        </a>
        <a href="https://github.com/openleash/openleash/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">
          <img src="https://img.shields.io/badge/License-Apache_2.0-10b981?style=flat" alt="Apache 2.0 License" width="auto" height="20" loading="lazy" />
        </a>
      </div>
      <div class="hero-actions fade-in fade-in-d1">
        <a href="/getting-started" class="btn btn-primary">Get Started</a>
        <a href="https://github.com/openleash/openleash" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
          GitHub
        </a>
      </div>
    </header>

    <div class="audience-band fade-in fade-in-d2">
      <div class="audience-card">
        <span class="audience-tag">For agent developers</span>
        <p class="audience-body">
          Wrap any risky action with one call. Your agent can't overspend, call random APIs,
          or take irreversible actions without policy approval — and you get human-in-the-loop
          escalation for free.
        </p>
        <p class="audience-meta">
          SDKs for TypeScript, Python, Go. Works with LangChain, LlamaIndex, AutoGen, CrewAI, MCP servers.
        </p>
        <a href="/getting-started" class="audience-cta">Add to your agent →</a>
      </div>
      <div class="audience-card audience-card-security">
        <span class="audience-tag">For security &amp; compliance</span>
        <p class="audience-body">
          Every agent action is policy-checked, logged, and produces a cryptographic proof token
          (PASETO v4.public, Ed25519-signed). Append-only audit log. Policies as YAML,
          version-controlled in your repo.
        </p>
        <p class="audience-meta">
          Runs locally next to your agent. No data leaves your network. Self-hostable.
        </p>
        <a href="/use-cases" class="audience-cta">See use cases →</a>
      </div>
    </div>

    <div class="fade-in fade-in-d2" style="margin-top: 24px; margin-bottom: 56px;">
      <CalloutBanner
        text="Works as a sidecar for OpenClaw. Also works with any agent."
        href="/openclaw"
        linkText="Learn more"
      />
    </div>

    <div class="fade-in fade-in-d2 hero-video-wrapper">
      <p class="hero-video-caption">See the owner portal in action</p>
      <video
        class="hero-video"
        controls
        playsinline
        preload="metadata"
        width="1280"
        height="720"
        poster="/video/poster.png"
        title="OpenLeash Owner Portal Demo"
        aria-label="Video walkthrough of the OpenLeash owner portal showing agent management, policies, approvals, and audit logs"
      >
        <source src="/video/pr_video_1.0.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- Quickstart -->
    <QuickStart />

    <section class="section fade-in fade-in-d3">
      <div class="sdk-example">
        <h3 class="subsection-title">Add OpenLeash to your agent</h3>
        <p class="sdk-intro">
          Wrap any risky action with one call. Your agent gets a decision and a cryptographic
          proof token it can attach to the action.
        </p>

        <div class="lang-tabs" role="tablist" aria-label="SDK language">
          <button class="lang-tab active" role="tab" aria-selected="true" data-lang="ts" id="lang-tab-ts">TypeScript</button>
          <button class="lang-tab" role="tab" aria-selected="false" data-lang="py" id="lang-tab-py">Python</button>
          <button class="lang-tab" role="tab" aria-selected="false" data-lang="go" id="lang-tab-go">Go</button>
        </div>

        <div class="lang-panel" role="tabpanel" data-lang="ts" aria-labelledby="lang-tab-ts">
          <CodeBlock
            title="agent.ts"
            lines={[
              { type: 'comment', text: '// Before — your agent acts directly' },
              { type: 'code', text: 'await sendEmail({ to, subject, body });' },
              { type: 'code', text: '' },
              { type: 'comment', text: '// After — your agent asks OpenLeash first' },
              { type: 'code', text: 'import { authorize } from "@openleash/sdk-ts";' },
              { type: 'code', text: '' },
              { type: 'code', text: 'const result = await authorize({' },
              { type: 'code', text: '  openleashUrl: process.env.OPENLEASH_URL!,' },
              { type: 'code', text: '  agentId: process.env.OPENLEASH_AGENT_ID!,' },
              { type: 'code', text: '  privateKeyB64: process.env.OPENLEASH_AGENT_KEY!,' },
              { type: 'code', text: '  action: {' },
              { type: 'code', text: '    action_id: crypto.randomUUID(),' },
              { type: 'code', text: '    action_type: "send_email",' },
              { type: 'code', text: '    requested_at: new Date().toISOString(),' },
              { type: 'code', text: '    principal: { agent_id: process.env.OPENLEASH_AGENT_ID! },' },
              { type: 'code', text: '    subject: { principal_id: ownerId },' },
              { type: 'code', text: '    relying_party: { domain: "your-app.com", trust_profile: "LOW" },' },
              { type: 'code', text: '    payload: { to, subject, body },' },
              { type: 'code', text: '  },' },
              { type: 'code', text: '});' },
              { type: 'code', text: '' },
              { type: 'code', text: 'if (result.decision !== "ALLOW") {' },
              { type: 'code', text: '  throw new Error(`Action ${result.decision}`);' },
              { type: 'code', text: '}' },
              { type: 'code', text: '' },
              { type: 'code', text: 'await sendEmail({ to, subject, body });' },
              { type: 'comment', text: '// result.proof_token — share or store as a verifiable receipt' },
            ]}
          />
        </div>

        <div class="lang-panel hidden" role="tabpanel" data-lang="py" aria-labelledby="lang-tab-py">
          <CodeBlock
            title="agent.py"
            lines={[
              { type: 'comment', text: '# Before — your agent acts directly' },
              { type: 'code', text: 'send_email(to=to, subject=subject, body=body)' },
              { type: 'code', text: '' },
              { type: 'comment', text: '# After — your agent asks OpenLeash first' },
              { type: 'code', text: 'from openleash import authorize' },
              { type: 'code', text: '' },
              { type: 'code', text: 'result = await authorize(' },
              { type: 'code', text: '    openleash_url=os.environ["OPENLEASH_URL"],' },
              { type: 'code', text: '    agent_id=os.environ["OPENLEASH_AGENT_ID"],' },
              { type: 'code', text: '    private_key_b64=os.environ["OPENLEASH_AGENT_KEY"],' },
              { type: 'code', text: '    action={' },
              { type: 'code', text: '        "action_id": str(uuid.uuid4()),' },
              { type: 'code', text: '        "action_type": "send_email",' },
              { type: 'code', text: '        "requested_at": datetime.now(timezone.utc).isoformat(),' },
              { type: 'code', text: '        "principal": {"agent_id": os.environ["OPENLEASH_AGENT_ID"]},' },
              { type: 'code', text: '        "subject": {"principal_id": owner_id},' },
              { type: 'code', text: '        "relying_party": {"domain": "your-app.com", "trust_profile": "LOW"},' },
              { type: 'code', text: '        "payload": {"to": to, "subject": subject, "body": body},' },
              { type: 'code', text: '    },' },
              { type: 'code', text: ')' },
              { type: 'code', text: '' },
              { type: 'code', text: 'if result["decision"] != "ALLOW":' },
              { type: 'code', text: '    raise Exception(f"Action {result[\'decision\']}")' },
              { type: 'code', text: '' },
              { type: 'code', text: 'send_email(to=to, subject=subject, body=body)' },
              { type: 'comment', text: '# result["proof_token"] — share or store as a verifiable receipt' },
            ]}
          />
        </div>

        <div class="lang-panel hidden" role="tabpanel" data-lang="go" aria-labelledby="lang-tab-go">
          <CodeBlock
            title="agent.go"
            lines={[
              { type: 'comment', text: '// Before — your agent acts directly' },
              { type: 'code', text: 'sendEmail(to, subject, body)' },
              { type: 'code', text: '' },
              { type: 'comment', text: '// After — your agent asks OpenLeash first' },
              { type: 'code', text: 'import openleash "github.com/openleash/openleash/packages/sdk-go"' },
              { type: 'code', text: '' },
              { type: 'code', text: 'result, err := openleash.Authorize(' },
              { type: 'code', text: '    os.Getenv("OPENLEASH_URL"),' },
              { type: 'code', text: '    os.Getenv("OPENLEASH_AGENT_ID"),' },
              { type: 'code', text: '    os.Getenv("OPENLEASH_AGENT_KEY"),' },
              { type: 'code', text: '    map[string]interface{}{' },
              { type: 'code', text: '        "action_id":     uuid.New().String(),' },
              { type: 'code', text: '        "action_type":   "send_email",' },
              { type: 'code', text: '        "requested_at":  time.Now().UTC().Format(time.RFC3339),' },
              { type: 'code', text: '        "principal":     map[string]string{"agent_id": os.Getenv("OPENLEASH_AGENT_ID")},' },
              { type: 'code', text: '        "subject":       map[string]string{"principal_id": ownerID},' },
              { type: 'code', text: '        "relying_party": map[string]interface{}{"domain": "your-app.com", "trust_profile": "LOW"},' },
              { type: 'code', text: '        "payload":       map[string]interface{}{"to": to, "subject": subject, "body": body},' },
              { type: 'code', text: '    },' },
              { type: 'code', text: ')' },
              { type: 'code', text: 'if err != nil { return err }' },
              { type: 'code', text: '' },
              { type: 'code', text: 'if result["decision"] != "ALLOW" {' },
              { type: 'code', text: '    return fmt.Errorf("action %v", result["decision"])' },
              { type: 'code', text: '}' },
              { type: 'code', text: '' },
              { type: 'code', text: 'sendEmail(to, subject, body)' },
              { type: 'comment', text: '// result["proof_token"] — share or store as a verifiable receipt' },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- What you get back -->
    <section class="section">
      <h2 class="section-title">
        <span class="accent-prefix">›</span> What you get back
      </h2>
      <p class="section-intro">
        Every approved action returns a <strong>PASETO v4.public</strong> proof token — Ed25519-signed,
        offline-verifiable by anyone with the public key. The same decision is written to an
        append-only audit log scoped per user, organization, and agent.
      </p>

      <div class="proof-grid">
        <div class="proof-block">
          <h3 class="subsection-title">Decoded proof token</h3>
          <CodeBlock
            title="proof_token (claims)"
            lines={[
              { type: 'code', text: '{' },
              { type: 'code', text: '  "iss": "openleash",' },
              { type: 'code', text: '  "sub": "agent_01h8x...",' },
              { type: 'code', text: '  "aud": "your-app.com",' },
              { type: 'code', text: '  "iat": "2026-05-05T13:42:11Z",' },
              { type: 'code', text: '  "exp": "2026-05-05T13:47:11Z",' },
              { type: 'code', text: '  "action_id": "8e3b...",' },
              { type: 'code', text: '  "action_type": "send_email",' },
              { type: 'code', text: '  "action_hash": "sha256:b1a7...",' },
              { type: 'code', text: '  "decision": "ALLOW",' },
              { type: 'code', text: '  "policy_id": "default-mail",' },
              { type: 'code', text: '  "kid": "k1"' },
              { type: 'code', text: '}' },
            ]}
          />
        </div>

        <div class="proof-block">
          <h3 class="subsection-title">Audit log entry (JSONL)</h3>
          <CodeBlock
            title="audit.log.jsonl"
            lines={[
              { type: 'code', text: '{' },
              { type: 'code', text: '  "ts": "2026-05-05T13:42:11Z",' },
              { type: 'code', text: '  "actor_type": "agent",' },
              { type: 'code', text: '  "actor_id": "agent_01h8x...",' },
              { type: 'code', text: '  "action_type": "send_email",' },
              { type: 'code', text: '  "action_id": "8e3b...",' },
              { type: 'code', text: '  "decision": "ALLOW",' },
              { type: 'code', text: '  "policy_id": "default-mail",' },
              { type: 'code', text: '  "proof_kid": "k1",' },
              { type: 'code', text: '  "signature_valid": true' },
              { type: 'code', text: '}' },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="section">
      <h2 class="section-title">
        <span class="accent-prefix">›</span> How AI Agent Authorization Works
      </h2>
      <p class="section-intro">
        Alice's agent purchases headphones from StoreCo's agent. Both sides use OpenLeash to authorize actions and exchange cryptographic proofs.
      </p>
      <TransactionFlow />
    </section>

    <!-- Use cases -->
    <section class="section">
      <h2 class="section-title">
        <span class="accent-prefix">›</span> AI Agent Authorization Use Cases
      </h2>
      <div class="features-grid">
        <FeatureCard
          icon="💳"
          title="Purchases with limits"
          description="Set spending caps per agent, per vendor, or per time window. Agents cannot exceed policy limits without step-up approval."
        />
        <FeatureCard
          icon="📅"
          title="Appointment booking"
          description="Differentiate trust levels: a haircut booking might auto-approve while a medical appointment requires human confirmation."
        />
        <FeatureCard
          icon="🏛️"
          title="Government submissions"
          description="Regulated filings and submissions can require step-up authentication, producing auditable proof tokens for compliance."
        />
        <FeatureCard
          icon="📡"
          title="Communication rules"
          description="Enforce allowlists and denylists for API calls, emails, or messages. Agents only reach approved endpoints."
        />
      </div>
      <p class="section-more">
        <a href="/use-cases">See all use cases and FAQ →</a>
      </p>
    </section>

    <!-- Compared to other tools -->
    <section class="section">
      <h2 class="section-title">
        <span class="accent-prefix">›</span> How OpenLeash Compares
      </h2>
      <p class="section-intro">
        OpenLeash is opinionated for AI agents. If you're already using a general-purpose policy engine, here's how the boundaries differ — and where each tool wins.
      </p>
      <div class="compare-grid">
        <a href="/concepts/openleash-vs-opa" class="compare-card">
          <div class="compare-card-title">vs OPA</div>
          <p class="compare-card-desc">General-purpose policy engine versus AI-agent-specific sidecar with built-in identity, approvals, and proof tokens.</p>
          <span class="compare-card-arrow">Read comparison →</span>
        </a>
        <a href="/concepts/openleash-vs-cedar" class="compare-card">
          <div class="compare-card-title">vs Cedar</div>
          <p class="compare-card-desc">AWS's embedded authorization library versus a sidecar service with cryptographic proof tokens and approval workflows.</p>
          <span class="compare-card-arrow">Read comparison →</span>
        </a>
        <a href="/concepts/openleash-vs-openfga" class="compare-card">
          <div class="compare-card-title">vs OpenFGA</div>
          <p class="compare-card-desc">Relationship-based access (Zanzibar-style) versus action-level governance for autonomous agents.</p>
          <span class="compare-card-arrow">Read comparison →</span>
        </a>
      </div>
    </section>

    <!-- Features -->
    <section class="section" id="features">
      <h2 class="section-title">
        <span class="accent-prefix">›</span> Features
      </h2>

      <div class="mvp-grid">
        <div class="mvp-item">
          <span class="mvp-icon" aria-hidden="true">📁</span>
          <div>
            <strong>YAML policies</strong>
            <p>Authorization rules as YAML. Constraints, obligations, schema-validated. No database, no cloud dependency, version-controlled in your repo.</p>
          </div>
        </div>
        <div class="mvp-item">
          <span class="mvp-icon" aria-hidden="true">🔑</span>
          <div>
            <strong>PASETO proof tokens</strong>
            <p>PASETO v4.public, Ed25519-signed. Bound to a specific action and verifiable offline by any counterparty with the public key.</p>
          </div>
        </div>
        <div class="mvp-item">
          <span class="mvp-icon" aria-hidden="true">✅</span>
          <div>
            <strong>Approval workflow</strong>
            <p>Human-in-the-loop for high-risk actions. Agents request approval; owners approve or deny in the portal. Tokens are single-use and action-scoped.</p>
          </div>
        </div>
        <div class="mvp-item">
          <span class="mvp-icon" aria-hidden="true">📋</span>
          <div>
            <strong>Append-only audit log</strong>
            <p>Every authorization, approval, and policy change in JSONL. Scope filtering by user, organization, or agent.</p>
          </div>
        </div>
        <div class="mvp-item">
          <span class="mvp-icon" aria-hidden="true">📦</span>
          <div>
            <strong>Multi-language SDKs</strong>
            <p>TypeScript, Python, and Go SDKs at endpoint parity. 13 functions each — authorize, sign, verify, approvals, policy drafts.</p>
          </div>
        </div>
        <div class="mvp-item">
          <span class="mvp-icon" aria-hidden="true">🤖</span>
          <div>
            <strong>Agent registration</strong>
            <p>Invite-based onboarding with Ed25519 keys. Every request is signed, timestamp-bound, and replay-protected.</p>
          </div>
        </div>
