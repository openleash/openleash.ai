    }

    .hero-video-wrapper {
      border-radius: 10px;
    }

    .hero-video {
      border-radius: 6px;
    }

    .pro-callout-inner {
      border-radius: var(--radius-md);
      gap: 8px;
      padding: 10px 14px;
      flex-wrap: wrap;
    }

    .pro-callout-text {
      font-size: 0.8rem;
    }

    .pro-teaser {
      padding: 20px 16px;
    }

    .pro-teaser-header {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  fetch('https://api.github.com/repos/openleash/openleash/releases/latest')
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(data => {
      const el = document.getElementById('hero-version');
      const tag = document.getElementById('version-tag');
      const link = document.getElementById('version-link');
      if (el && tag && link && data.tag_name) {
        tag.textContent = data.tag_name;
        link.href = data.html_url;
        el.style.display = '';
      }
    })
    .catch(() => {});

  document.querySelectorAll<HTMLButtonElement>('.lang-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const lang = tab.dataset.lang;
      if (!lang) return;
      document.querySelectorAll<HTMLButtonElement>('.lang-tab').forEach((t) => {
        const active = t.dataset.lang === lang;
        t.classList.toggle('active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll<HTMLDivElement>('.lang-panel').forEach((p) => {
        p.classList.toggle('hidden', p.dataset.lang !== lang);
      });
    });
  });
</script>
