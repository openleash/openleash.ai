---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const proFeatures = [
  {
    icon: '🔐',
    title: 'Firebase Authentication',
    description: 'Persistent client-side sessions with Firebase Auth. Google Sign-in, email/password registration, and automatic session renewal. No long-lived tokens stored server-side.',
  },
  {
    icon: '🏦',
    title: 'Swedish BankID',
    description: 'Government-level identity verification with animated QR codes for cross-device flows. Mutual TLS with the BankID RP API. Digital signatures stored as cryptographic proof.',
  },
  {
    icon: '🏢',
    title: 'Company registry lookup',
    description: 'Verify company registrations against official registries. Bolagsverket integration for Swedish companies. Registry-level proof storage for compliance.',
  },
  {
    icon: '📱',
    title: 'SMS & Email OTP',
    description: 'Secondary verification via one-time passwords. SMS delivery through 46elks or Twilio. Email OTP via SMTP or SendGrid. PASETO attestation tokens for verified identities.',
  },
  {
    icon: '☁️',
    title: 'Cloud database',
    description: 'Google Cloud Firestore as a scalable alternative to file-based storage. Write-through caching, automatic state bootstrapping, and collection-prefix isolation for multi-tenancy.',
  },
  {
    icon: '🔔',
    title: 'Push notifications',
    description: 'Firebase Cloud Messaging for mobile and web push. Real-time alerts when agents request approval or propose policy drafts. Per-device token management with automatic cleanup.',
  },
  {
    icon: '🖥️',
    title: 'Hosted GUI',
    description: 'Professional login and registration interface with branded email communications. Email verification flow with welcome emails. Dual-mode authentication for maximum flexibility.',
  },
  {
    icon: '🚀',
    title: 'Managed deployment',
    description: 'Google Cloud Run with full infrastructure management. Automatic scaling, TLS termination, and regional deployment. No servers to maintain.',
  },
  {
    icon: '🏗️',
    title: 'Multi-tenant support',
    description: 'Run multiple isolated tenants on shared infrastructure. Collection prefix isolation in Firestore ensures complete data separation between environments.',
  },
  {
    icon: '📧',
    title: 'Email service',
    description: 'Built-in email abstraction with SMTP and SendGrid backends. HTML-templated transactional emails for verification, invites, and notifications. Zero-dependency SMTP using native Node.js.',
  },
];
---

<BaseLayout
  title="OpenLeash Pro — Hosted AI Agent Authorization"
  description="OpenLeash Pro: hosted authorization with Firebase Auth, Swedish BankID, push notifications, Firestore storage, and managed Cloud Run deployment. Coming soon."
  canonicalPath="/pro"
>
  <Nav />

  <main class="container">
    <!-- Header -->
    <header class="page-header fade-in">
      <h1 class="page-title">
        Open<span class="title-accent">Leash</span> Pro
      </h1>
      <span class="coming-soon-badge">Coming Soon</span>
      <p class="page-subtitle">
        Everything in the open-source edition, plus hosted infrastructure,
        enterprise authentication, and managed deployment.
      </p>
    </header>

    <!-- OSS foundation callout -->
    <div class="oss-callout fade-in fade-in-d1">
      <div class="oss-callout-inner">
        <span class="oss-icon" aria-hidden="true">🦞</span>
        <div>
          <strong>Built on the open-source foundation</strong>
          <p>
            All <a href="/#features">core features</a> are included — YAML policies, PASETO proof tokens,
            approval workflows, multi-language SDKs, organizations, RBAC, and more.
            Pro adds hosted infrastructure and enterprise integrations on top.
          </p>
        </div>
      </div>
    </div>

    <!-- Pro features -->
    <section class="section fade-in fade-in-d2">
      <h2 class="section-title">
        <span class="accent-prefix">›</span> What Pro adds
      </h2>
      <div class="pro-grid">
        {proFeatures.map((feature) => (
          <div class="pro-item">
            <span class="pro-icon" aria-hidden="true">{feature.icon}</span>
            <div>
              <strong>{feature.title}</strong>
              <p>{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Interest -->
    <section class="interest-section fade-in fade-in-d3">
      <div class="interest-block">
        <h2 class="interest-title">Interested in OpenLeash Pro?</h2>
        <p class="interest-desc">
          We are building the hosted version of OpenLeash. Follow the project on GitHub
          for updates, or join the discussion to share what features matter most to you.
        </p>
        <div class="interest-links">
          <a href="https://github.com/openleash/openleash" target="_blank" rel="noopener noreferrer" class="btn btn-amber">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
          <a href="https://github.com/openleash/openleash/discussions" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            Discussions
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Header */
  .page-header {
    text-align: center;
    padding-top: 48px;
    margin-bottom: 40px;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    font-weight: 700;
    background: linear-gradient(135deg, #e8f0f8, #fbbf24, #f59e0b);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 16px;
  }

  .title-accent {
    /* Gradient handles coloring */
  }

  .coming-soon-badge {
    display: inline-block;
    padding: 6px 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--amber-mid), var(--amber-bright));
    color: #050a0e;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }

  .page-subtitle {
    max-width: 560px;
    margin: 0 auto;
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* OSS callout */
  .oss-callout {
    margin-bottom: 48px;
  }

  .oss-callout-inner {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 20px 24px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-accent);
    background: rgba(52, 211, 153, 0.04);
    backdrop-filter: blur(12px);
  }

  .oss-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .oss-callout-inner strong {
    display: block;
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .oss-callout-inner p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Section */
  .section {
    margin-bottom: 56px;
    position: relative;
    z-index: 1;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 24px;
    color: var(--text-primary);
  }

  .accent-prefix {
    color: var(--amber-bright);
    margin-right: 4px;
  }

  /* Pro grid */
  .pro-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .pro-item {
    display: flex;
    gap: 14px;
    padding: 16px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-amber);
    background: var(--surface-card);
    backdrop-filter: blur(12px);
    transition: all 0.25s var(--ease-out);
  }

  .pro-item:hover {
    border-color: var(--amber-bright);
  }

  .pro-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .pro-item strong {
    display: block;
    font-size: 0.9rem;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .pro-item p {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Interest */
  .interest-section {
    margin-bottom: 48px;
    position: relative;
    z-index: 1;
  }

  .interest-block {
    padding: 32px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-amber);
    background: rgba(251, 191, 36, 0.03);
    backdrop-filter: blur(12px);
    text-align: center;
  }

  .interest-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .interest-desc {
    max-width: 520px;
    margin: 0 auto 24px;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .interest-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-display);
    text-decoration: none;
    transition: all 0.2s var(--ease-out);
    cursor: pointer;
  }

  .btn-amber {
    background: linear-gradient(135deg, var(--amber-mid), var(--amber-bright));
    color: #050a0e;
  }

  .btn-amber:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(251, 191, 36, 0.3);
    color: #050a0e;
  }

  .btn-secondary {
    background: transparent;
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
  }

  .btn-secondary:hover {
    border-color: var(--amber-bright);
    color: var(--amber-bright);
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .pro-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .page-header {
      padding-top: 32px;
    }

    .oss-callout-inner {
      flex-direction: column;
      gap: 12px;
    }

    .interest-block {
      padding: 24px 16px;
    }
  }
</style>
